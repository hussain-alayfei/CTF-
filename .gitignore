node_modules
dist
dist-ssr
*.local
*.log
# Challenge artifacts intentionally use .log as a file extension (e.g. Day 5
# request-gateway.log, tor-access-gate.log) and must NOT be swallowed by the
# blanket *.log rule above — that's what caused them to silently never be
# committed, so the deployed site 404'd on their download links.
!public/challenges/**/*.log

# Env
.env
.env.local
.env.*.local

.DS_Store
.vercel
*.tsbuildinfo

# Local DB safety backups (contain player data — never commit)
backups/
